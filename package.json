{
  "name": "react-native-ref-ads",
  "version": "1.0.0",
  "description": "Highly flexible, customizable React Native ad components for Expo. Build native-feeling ads with full UI control.",
  "main": "./lib/module/index.js",
  "module": "./lib/module/index.js",
  "react-native": "./src/index.ts",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "lib",
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "react-native",
    "expo",
    "ads",
    "advertising",
    "native-ads",
    "banner",
    "interstitial",
    "rewarded",
    "flexible",
    "customizable",
    "ios",
    "android",
    "typescript",
    "ui-components"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sagintel/react-native-ref-ads.git"
  },
  "bugs": {
    "url": "https://github.com/sagintel/react-native-ref-ads/issues"
  },
  "homepage": "https://github.com/sagintel/react-native-ref-ads#readme",
  "author": "sagintel <[EMAIL_ADDRESS]>",
  "license": "MIT",
  "scripts": {
    "build": "bob build",
    "clean": "del-cli lib",
    "prebuild": "npm run clean",
    "prepare": "bob build",
    "prepack": "bob build",
    "test": "jest",
    "test:ci": "jest --coverage --ci --runInBand",
    "test:watch": "jest --watch",
    "lint": "eslint src example --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint src example --ext .ts,.tsx,.js,.jsx --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\" \"example/**/*.{ts,tsx,js,jsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json}\" \"example/**/*.{ts,tsx,js,jsx,json}\"",
    "release": "np",
    "version": "npm run format && git add -A",
    "postversion": "git push && git push --tags"
  },
  "dependencies": {
    "react-native-gesture-handler": "~2.16.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.73.0",
    "expo": ">=50.0.0",
    "expo-image": "~1.12.0",
    "expo-av": "~14.0.0",
    "expo-linking": "~6.3.0",
    "expo-modules-core": "~1.12.0"
  },
  "peerDependenciesMeta": {
    "expo": {
      "optional": false
    },
    "expo-image": {
      "optional": false
    },
    "expo-av": {
      "optional": false
    },
    "expo-linking": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/react": "~18.2.79",
    "@types/react-native": "~0.73.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "del-cli": "^5.1.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-native": "^4.1.0",
    "jest": "^29.7.0",
    "jest-expo": "~51.0.0",
    "np": "^10.0.0",
    "prettier": "^3.2.5",
    "react": "18.2.0",
    "react-native": "0.74.0",
    "react-native-builder-bob": "^0.40.0",
    "react-test-renderer": "18.2.0",
    "typescript": "~5.3.3"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      "typescript"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}